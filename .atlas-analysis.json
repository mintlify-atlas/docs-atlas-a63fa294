  "keyFeatures": [
    "100,000+ community AI prompts for ChatGPT, Claude, Gemini, and more",
    "Prompt versioning and change request system (similar to GitHub PRs)",
    "MCP (Model Context Protocol) server for AI tool integrations",
    "Self-hostable with white-label branding for organizations",
    "Multi-language support with 17 locales",
    "AI-powered semantic search",
    "Private prompts and collections",
    "Claude Code plugin and CLI integration",
    "Structured prompts (JSON/YAML), image prompts, skills, and workflows",
    "Community voting, leaderboard, and PromptMasters"
  ],
  "publicApiSurface": [
    "GET /api/prompts — List prompts with filtering and pagination",
    "POST /api/prompts — Create a new prompt",
    "GET /api/prompts/:id — Get a prompt by ID",
    "GET /api/prompts/search — Search prompts by keyword",
    "GET /api/categories — List all categories",
    "GET /api/tags — List all tags",
    "GET /api/users/:username — Get user profile",
    "GET /api/search — Semantic/full-text search",
    "GET /api/mcp — MCP server endpoint",
    "GET /api/health — Health check",
    "GET /api/config — Public configuration"
  ]
